<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Clasificación Porra del Mundial 2026</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <h1>Clasificación Porra del Mundial 2026</h1>

  <div class="upload-box">
    <label for="csvFile" class="btn">Seleccionar archivo CSV</label>
    <input type="file" id="csvFile" accept=".csv">

    <div id="dropZone" class="drop-zone">
      Arrastra aquí el archivo CSV
    </div>
  </div>

  <table id="tabla">
    <thead>
      <tr>
        <th>Pos</th>
        <th>Jugador</th>
        <th>Grupos</th>
        <th>16avos</th>
        <th>Octavos</th>
        <th>Cuartos</th>
        <th>Semis</th>
        <th>Final</th>
        <th>3º y 4º</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <script src="app.js"></script>
</body>
</html>
